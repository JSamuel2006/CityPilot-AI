# CityPilot AI — Frontend Environment Variables
# Copy this file to .env.local for local development
# In Vercel: set these under Project → Settings → Environment Variables

# ── Required ──────────────────────────────────────────────────────────────
# URL of the deployed FastAPI backend (no trailing slash)
# Local development:
VITE_API_URL=http://localhost:8000

# Production (replace with your actual Render service URL):
# VITE_API_URL=https://citypilot-backend.onrender.com
